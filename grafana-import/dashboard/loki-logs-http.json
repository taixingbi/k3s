{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Grafana Cloud Loki (same datasource as Explore → Loki)",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "HTTP status from JSON log lines (`status`, `path`, `duration_ms`; tune to your schema)",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineInterpolation": "smooth", "showPoints": "never" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum(count_over_time({cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | status >= 400 and status < 500 [$__auto]))",
          "legendFormat": "4xx lines",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "4xx log lines (rate via count_over_time)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "smooth", "showPoints": "never" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum(count_over_time({cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | status >= 500 [$__auto]))",
          "legendFormat": "5xx lines",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "5xx log lines (error burst signal)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "showPoints": "never" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "quantile_over_time(0.95, {cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | unwrap duration_ms [$__auto])",
          "legendFormat": "p95 duration_ms",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "p95 latency (unwrap `duration_ms` from JSON)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "showPoints": "never" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "quantile_over_time(0.99, {cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | unwrap duration_ms [$__auto])",
          "legendFormat": "p99 duration_ms",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "p99 latency (unwrap `duration_ms`)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "showPoints": "never" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 17 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum by (path) (count_over_time({cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | status >= 500 [$__auto]))",
          "legendFormat": "{{path}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "5xx volume by `path` (count_over_time; burst detector)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 25 },
      "id": 6,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "p99", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "topk(15, sum by (path) (quantile_over_time(0.99, {cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | unwrap duration_ms [5m])))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top slow routes (p99 of `duration_ms` over 5m windows)",
      "transformations": [],
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" },
          "unit": "ms"
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 25 },
      "id": 7,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "topk(15, sum by (path) (avg_over_time({cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | __error__=\"\" | unwrap duration_ms [5m])))",
          "instant": true,
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Top routes by avg `duration_ms` (5m)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 35 },
      "id": 8,
      "options": { "dedupStrategy": "none", "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "{cluster=\"k3s\", namespace=~\"$namespace\", app=~\"$app\"} | json | status >= 500",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent 5xx log lines",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["loki", "logs", "http", "k3s"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "ai", "value": "ai" },
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "namespace",
        "options": [],
        "query": "label_values({cluster=\"k3s\"}, namespace)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "app",
        "options": [],
        "query": "label_values({cluster=\"k3s\", namespace=~\"$namespace\"}, app)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Loki — HTTP / JSON (4xx, 5xx, latency, routes)",
  "uid": "layer-loki-http-logs",
  "version": 1
}
