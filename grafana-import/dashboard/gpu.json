  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["dcgm", "gpu"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GPU (DCGM)",
  "uid": "layer-gpu-dcgm",
  "version": 1
